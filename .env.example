# ============================================
# RivalScope — Environment Variables
# Copy this file to .env.local and fill values
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=RivalScope

# Database (Neon PostgreSQL — free tier at neon.tech)
DATABASE_URL=postgresql://user:password@host/rivalscope?sslmode=require

# Auth (Better Auth)
BETTER_AUTH_SECRET=              # openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRO_PRICE_ID=price_
STRIPE_AGENCY_PRICE_ID=price_

# Resend (resend.com — 3k emails/month free)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=hello@rivalscope.com

# Trigger.dev (trigger.dev — background jobs)
TRIGGER_SECRET_KEY=tr_

# PostHog (posthog.com — 1M events free)
VITE_POSTHOG_KEY=phc_
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry (sentry.io — error tracking)
VITE_SENTRY_DSN=

# OpenAI (for AI diff summaries)
OPENAI_API_KEY=sk-
